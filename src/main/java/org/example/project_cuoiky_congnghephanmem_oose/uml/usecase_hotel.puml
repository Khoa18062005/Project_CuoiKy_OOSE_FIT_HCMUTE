@startuml Hotel Booking UseCase Diagram

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Khách vãng lai" as Guest
actor "Khách hàng" as Customer
actor "Quản lý" as Manager

Customer --|> Guest

rectangle "Hệ thống đặt phòng khách sạn" {

  package "Chức năng công khai" {
    usecase "Xem danh sách phòng trống" as UC1
    usecase "Tìm kiếm phòng\n(ngày, loại phòng, số lượng phòng, số người)" as UC4
    usecase "Đăng ký tài khoản" as UC2
  }

  package "Chức năng khách hàng" {
    usecase "Đăng nhập" as UC3
    usecase "Đặt phòng" as UC5
    usecase "Thanh toán online" as UC6
    usecase "Nhận mail xác nhận" as UC7
    usecase "Xem lịch sử đặt phòng" as UC8
    usecase "Xem & cập nhật thông tin cá nhân\n(tên, email, SĐT, ngày sinh, avatar)" as UC9
    usecase "Theo dõi hạng thành viên\n& điểm tích lũy" as UC10
    usecase "Quản lý tài khoản cá nhân" as UC17
  }

  package "Chức năng quản lý" {
    usecase "Xem danh sách booking\ncủa khách hàng" as UC11
    usecase "Cập nhật trạng thái phòng\n(trống, đã đặt, bảo trì)" as UC12
    usecase "Điều chỉnh thông tin phòng\n(giá, loại, sức chứa)" as UC13
    usecase "Xem tổng doanh thu" as UC14
    usecase "Xem khách hàng tiềm năng" as UC15
    usecase "Quản lý phòng" as UC16
  }
}

' Guest associations
Guest --> UC1
Guest --> UC2
Guest --> UC4

' Customer associations – now only to the new account management and the other main use cases
Customer --> UC3
Customer --> UC5
Customer --> UC6
Customer --> UC8
Customer --> UC17

' Manager associations – now only to the new room management and the other main use cases
Manager --> UC11
Manager --> UC14
Manager --> UC15
Manager --> UC16

' Include relationships
UC5 .> UC3 : <<include>>
UC6 .> UC5 : <<include>>
UC7 .> UC6 : <<include>>
UC8 .> UC3 : <<include>>
UC9 .> UC3 : <<include>>
UC10 .> UC3 : <<include>>
UC17 .> UC9 : <<include>>
UC17 .> UC10 : <<include>>
UC16 .> UC12 : <<include>>
UC16 .> UC13 : <<include>>
UC17 .> UC8 : <<include>>

@enduml